                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "PERSONAL"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra",
          "renameFallbackOutput": "AI_UNSORTED"
        }
      },
      "notes": "One branch per category plus a fallback. The expression skips 'thought' parts so thinking models work too. If you edit categories in the AI prompt, edit them here as well."
    },
