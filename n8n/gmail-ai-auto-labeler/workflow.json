{
  "name": "Gmail AI Auto-Labeler",
  "nodes": [
    {
      "id": "c1c2c3d4-0000-4000-8000-000000000001",
      "name": "Setup notes",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        380,
        -40
      ],
      "parameters": {
        "width": 300,
        "height": 460,
        "content": "## Gmail AI auto-labeler\nAI reads every unread email and files it under one of six labels. Anything it can't place lands in AI_UNSORTED so misfires stay visible.\n\nSetup:\n1. Create these labels in Gmail first:\n   INVOICE, BANKING, ACTION_REQUIRED, NEWSLETTER, NOTIFICATION, PERSONAL, AI_UNSORTED\n2. Gmail Trigger: attach a Gmail OAuth2 credential\n3. Classify with AI: free API key from aistudio.google.com, saved as a Google Gemini(PaLM) Api credential. No card needed\n4. Each Label node: attach the same Gmail credential, then pick the matching label from the dropdown\n5. Send yourself a test email and hit Execute Workflow\n\nFull walkthrough is in the README next to this file."
      }
    },
    {
      "id": "c1c2c3d4-0000-4000-8000-000000000002",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [
        700,
        320
      ],
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "simple": false,
        "filters": {
          "readStatus": "unread"
        },
        "options": {}
      },
      "notes": "Polls every minute for unread mail. Add a q filter here if you only want to label certain senders."
    },
    {
      "id": "c1c2c3d4-0000-4000-8000-000000000003",
      "name": "Classify with AI",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1,
      "position": [
        960,
        320
      ],
      "retryOnFail": true,
      "maxTries": 4,
      "waitBetweenTries": 5000,
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "value": "models/gemma-4-26b-a4b-it",
          "mode": "list",
          "cachedResultName": "gemma-4-26b-a4b-it"
        },
        "messages": {
          "values": [
            {
              "content": "=You are an email classifier. Classify the email below into EXACTLY ONE of these categories:\n\nINVOICE - bills, receipts, payment requests, purchase orders\nBANKING - bank statements, transaction alerts, OTP codes, card and account notices\nACTION_REQUIRED - a person is waiting on a reply or a task from me\nNEWSLETTER - marketing, digests, promos, cold outreach, anything with an unsubscribe link\nNOTIFICATION - automated alerts and confirmations that need no reply\nPERSONAL - friends and family\n\nReply with ONLY the category name, nothing else.\n\nFrom: {{ $json.from?.value?.[0]?.address ?? '' }}\nSubject: {{ $json.subject }}\nBody: {{ ($json.text || '').substring(0, 1500) }}"
            }
          ]
        },
        "options": {}
      },
      "notes": "Free tier model. Swap the category list in the prompt to change your labels, then mirror the change in the Switch node."
    },
    {
      "id": "c1c2c3d4-0000-4000-8000-000000000004",
      "name": "Route by category",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        1240,
        320
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "id": "r1",
                    "leftValue": "={{ $json.content.parts.filter(p => !p.thought).pop().text.trim().toUpperCase().replace(/[^A-Z_ -]/g, '').trim().replace(/[ -]+/g, '_') }}",
                    "rightValue": "INVOICE",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "INVOICE"
            },
