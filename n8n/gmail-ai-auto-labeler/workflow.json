                },
                "conditions": [
                  {
                    "id": "r5",
                    "leftValue": "={{ $json.content.parts.filter(p => !p.thought).pop().text.trim().toUpperCase().replace(/[^A-Z_ -]/g, '').trim().replace(/[ -]+/g, '_') }}",
                    "rightValue": "NOTIFICATION",
                    "operator": {
                      "type": "string",
